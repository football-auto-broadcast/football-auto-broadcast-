<?xml version="1.0" ?>
<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003" ToolsVersion="4.0">
	<ImportGroup Label="PropertySheets">
		<Import Condition="$(pangowin32Imported)!=true" Project="pangowin32.props"/>
		<Import Condition="$(pangocairoImported)!=true" Project="pangocairo.props"/>
		<Import Condition="$(gdk_pixbuf_2_0Imported)!=true" Project="gdk-pixbuf-2.0.props"/>
		<Import Condition="$(cairoImported)!=true" Project="cairo.props"/>
		<Import Condition="$(cairo_gobjectImported)!=true" Project="cairo-gobject.props"/>
		<Import Condition="$(graphene_gobject_1_0Imported)!=true" Project="graphene-gobject-1.0.props"/>
		<Import Condition="$(gio_2_0Imported)!=true" Project="gio-2.0.props"/>
		<Import Condition="$(CommonImported)!=true" Project="Common.props"/>
	</ImportGroup>
	<PropertyGroup Label="UserMacros"/>
	<PropertyGroup>
		<gtk4Imported>true</gtk4Imported>
	</PropertyGroup>
	<ItemDefinitionGroup>
		<ClCompile>
			<AdditionalIncludeDirectories>$(GSTREAMER_1_0_ROOT_MSVC_X86_64)\include\gtk-4.0;%(AdditionalIncludeDirectories)</AdditionalIncludeDirectories>
		</ClCompile>
		<Link>
			<AdditionalLibraryDirectories>;%(AdditionalLibraryDirectories)</AdditionalLibraryDirectories>
			<AdditionalDependencies>gtk-4.lib;%(AdditionalDependencies)</AdditionalDependencies>
		</Link>
	</ItemDefinitionGroup>
	<ItemGroup/>
</Project>
