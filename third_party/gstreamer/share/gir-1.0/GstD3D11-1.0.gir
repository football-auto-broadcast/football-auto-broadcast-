    <class name="D3D11Device"
           c:symbol-prefix="d3d11_device"
           c:type="GstD3D11Device"
           version="1.22"
           parent="Gst.Object"
           glib:type-name="GstD3D11Device"
           glib:get-type="gst_d3d11_device_get_type"
           glib:type-struct="D3D11DeviceClass">
      <doc xml:space="preserve"
           filename="gst-libs\gst\d3d11\gstd3d11device.cpp"
           line="45">#GstD3D11Device wraps ID3D11Device and ID3D11DeviceContext for GPU resources
to be able to be shared among various elements. Caller can get native
Direct3D11 handles via getter method.
Basically Direct3D11 API doesn't require dedicated thread like that of
OpenGL context, and ID3D11Device APIs are supposed to be thread-safe.
But concurrent call for ID3D11DeviceContext and DXGI API are not allowed.
To protect such object, callers need to make use of gst_d3d11_device_lock()
and gst_d3d11_device_unlock()</doc>
      <source-position filename="gst-libs\gst\d3d11\gstd3d11device.h"
                       line="80"/>
      <constructor name="new"
                   c:identifier="gst_d3d11_device_new"
                   version="1.22">
        <source-position filename="gst-libs\gst\d3d11\gstd3d11device.h"
